# Environment variables for API host configuration

# For localhost development (iOS Simulator)
# Set DEV_API_HOST to 'localhost'
# For Expo Go on physical device, set DEV_API_HOST to your Mac's LAN IP (e.g., 192.168.1.5)
# Find your IP with: ifconfig | grep "inet " | grep -v 127.0.0.1
DEV_API_HOST=localhost